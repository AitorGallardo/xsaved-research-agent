# Anthropic API key — the agent's "brain" runs here.
ANTHROPIC_API_KEY=sk-ant-...

# Which Claude model the agent uses. Default is the most capable (Opus 4.8).
# For cheaper/faster runs while iterating: claude-haiku-4-5 or claude-sonnet-4-6.
AGENT_MODEL=claude-opus-4-8

# Path to the BUILT xsaved-mcp server the agent will spawn and drive.
# The agent acts as an MCP *client* of this server (agent → mcp → rag → Postgres).
MCP_SERVER_PATH=../xsaved-mcp/dist/index.js

# Passed through to the spawned xsaved-mcp server so it can reach the rag service.
RAG_API_URL=http://localhost:8790
